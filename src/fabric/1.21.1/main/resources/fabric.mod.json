{
  "schemaVersion": 1,
  "id": "fishcasting",
  "name": "Fabric make my resources load after Tide's so I can overwrite the recipes that conflict",
  "version": "1.0.0",
  "environment": "*",
  "license": "MIT",
  "depends": {
    "tide": "*"
  },
  "custom": {
    "fabric:resource_load_order": {
      "after": "tide"
    }
  }
}