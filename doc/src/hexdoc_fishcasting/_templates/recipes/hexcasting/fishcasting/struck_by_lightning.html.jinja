{% import "macros/textures.html.jinja" as texture_macros with context -%}

<details class="details-collapsible flay-recipe-details">
  {% block collapse %}
    <summary class="collapse-details">
      <span class="collapse-recipe-show">{{ _('hexdoc.recipe.show') }}</span>
      <span class="collapse-recipe-hide">{{ _('hexdoc.recipe.hide') }}</span>
    </summary>
  {% endblock collapse %}

  <div>
    {% block title %}<h5>{{ page.header }}</h5>{% endblock %}

    <div class="flay-recipe">
      {% block background %}
        <img
          class="flay-recipe-background"
          alt="Flay Mind Recipe GUI"
          src="{% block background_image %}{{
            'fishcasting:textures/gui/hexdoc/struck_by_lightning.png'|hexdoc_texture
          }}{% endblock %}"
        >
      {% endblock background %}

      {% block ingredient %}
        <div class="flay-recipe-block-ingredient">
          {{ texture_macros.render_icon(recipe.inTex) }}
        </div>
      {% endblock %}

      {% block cost %}
        <div class="flay-recipe-cost texture item-texture">
            <div class="texture item-texture">
          {{ texture_macros.render_icon(recipe.inTex) }}
            </div>
        </div>
      {% endblock cost %}

      {% block result %}
        <div class="flay-recipe-result">
          {{ texture_macros.render_icon(recipe.outTex) }}
        </div>
      {% endblock %}
    </div>
  </div>
</details>